cmd-timetransfer_addgroup-desc = Adds the minimum playtime needed for a predefined unlock group to a target ckey.
cmd-timetransfer_addgroup-help = Usage: timetransfer_addgroup <ckey/userId> <all|extended>

timetransfer-addgroup-error-args = Need exactly two arguments.
timetransfer-addgroup-invalid-group = Unknown group "{$group}". Available groups: all, extended.
timetransfer-addgroup-player-not-found = Player "{$player}" was not found.
timetransfer-addgroup-no-changes = Group "{$group}" is already satisfied for "{$player}". Nothing was added.
timetransfer-addgroup-success = Applied group "{$group}" to "{$player}". Updated {$trackers} tracker(s), added {$time}.
